# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Track bake outputs — regenerable from the authored images via bake_track_cli.gd (ADR-002).
# The 3 source images (heightmap.exr / surface.png / markers.png) ARE committed.
baked_track.tscn
ground_*.res

# throwaway probe scripts (headless verification, deleted after use)
_probe*
_gen_*

# raw audio drops: the processed asset is what ships; SOURCES.md records where to re-download
rallyrivals/assets/audio/_incoming/*
!rallyrivals/assets/audio/_incoming/README.md
!rallyrivals/assets/audio/_incoming/sources.txt

# font candidates: comparison-only, not shipped
rallyrivals/assets/fonts/candidates/
